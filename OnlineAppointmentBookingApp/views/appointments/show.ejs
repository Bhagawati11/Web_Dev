<%- include('../partials/header') %>

<section class="section">
  <div class="container">
    <div class="section-heading">
      <h1>Appointment Details</h1>
      <p>Review booking information and update the appointment status.</p>
    </div>

    <article class="detail-card appointment-detail">
      <div class="detail-card__header">
        <div>
          <h2><%= appointment.customerName %></h2>
          <p class="muted-text"><%= appointment.email %> &middot; <%= appointment.phone %></p>
        </div>
        <span class="status-badge status-<%= appointment.status ? appointment.status.toLowerCase() : 'pending' %>">
          <%= appointment.status || 'Pending' %>
        </span>
      </div>

      <div class="detail-grid">
        <div class="detail-group">
          <h3>Provider Information</h3>
          <p><strong>Name:</strong> <%= appointment.provider ? appointment.provider.name : 'Not assigned' %></p>
          <p><strong>Specialty:</strong> <%= appointment.provider ? appointment.provider.specialty : 'N/A' %></p>
          <p><strong>Location:</strong> <%= appointment.provider ? appointment.provider.location : 'N/A' %></p>
          <p><strong>Fee:</strong> <%= appointment.provider ? '₹' + appointment.provider.fee : 'N/A' %></p>
        </div>

        <div class="detail-group">
          <h3>Appointment Information</h3>
          <p><strong>Date:</strong> <%= appointment.appointmentDate %></p>
          <p><strong>Slot:</strong> <%= appointment.slot %></p>
          <p><strong>Reason:</strong> <%= appointment.reason %></p>
          <p><strong>Notes:</strong> <%= appointment.notes ? appointment.notes : 'No additional notes available.' %></p>
        </div>
      </div>

      <div class="detail-actions">
        <div class="status-actions">
          <form action="/appointments/<%= appointment._id %>/status?_method=PATCH" method="POST" class="inline-form">
            <input type="hidden" name="status" value="Confirmed">
            <button type="submit" class="btn btn-success">Mark Confirmed</button>
          </form>

          <form action="/appointments/<%= appointment._id %>/status?_method=PATCH" method="POST" class="inline-form">
            <input type="hidden" name="status" value="Completed">
            <button type="submit" class="btn btn-secondary">Mark Completed</button>
          </form>

          <form action="/appointments/<%= appointment._id %>/status?_method=PATCH" method="POST" class="inline-form">
            <input type="hidden" name="status" value="Cancelled">
            <button type="submit" class="btn btn-warning">Mark Cancelled</button>
          </form>
        </div>

        <div class="danger-zone">
          <form action="/appointments/<%= appointment._id %>?_method=DELETE" method="POST">
            <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this appointment?')">
              Delete Appointment
            </button>
          </form>
        </div>
      </div>
    </article>
  </div>
</section>

<%- include('../partials/footer') %>