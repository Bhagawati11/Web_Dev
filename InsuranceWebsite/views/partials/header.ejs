<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="container nav-container">
      <a href="/" class="brand">
        <span class="brand-icon">🛡</span>
        <span class="brand-name">InsureWell</span>
      </a>
      <div class="nav-links">
        <a href="/services">Services</a>
        <a href="/quotes">Get Quote</a>
        <a href="/about">About</a>
        <a href="/contact">Contact</a>
        <% if (user) { %>
          <a href="/policies">My Policies</a>
          <a href="/claims">My Claims</a>
          <a href="/auth/profile">👤 <%= user.name.split(" ")[0] %></a>
          <a href="/auth/logout" class="btn-nav btn-nav-primary">Logout</a>
        <% } else { %>
          <a href="/auth/login" class="btn-nav">Login</a>
          <a href="/auth/register" class="btn-nav btn-nav-primary">Get Started</a>
        <% } %>
      </div>
    </div>
  </nav>
  <main>
    <% if (success && success.length > 0) { %>
      <div class="flash flash-success"><%= success %></div>
    <% } %>
    <% if (error && error.length > 0) { %>
      <div class="flash flash-error"><%= error %></div>
    <% } %>
