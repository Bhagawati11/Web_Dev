<%- include('../partials/header') %>
<section class="dashboard-section">
  <div class="container form-container">
    <h1>File a New Claim</h1>
    <div class="auth-card" style="margin-top:24px;">
      <% if (policies.length === 0) { %>
        <div class="empty-state">
          <p>You don't have any active policies to file a claim against.</p>
          <a href="/policies/new" class="btn btn-primary" style="margin-top:16px;">Add a Policy First</a>
        </div>
      <% } else { %>
        <form action="/claims" method="POST" class="auth-form">
          <div class="form-group">
            <label>Select Policy</label>
            <select name="policy" required>
              <option value="">Choose a policy...</option>
              <% policies.forEach(p => { %>
                <option value="<%= p._id %>"><%= p.policyNumber %> — <%= p.type %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Claim Amount (₹)</label>
              <input type="number" name="claimAmount" required placeholder="50000">
            </div>
            <div class="form-group">
              <label>Incident Date</label>
              <input type="date" name="incidentDate" required>
            </div>
          </div>
          <div class="form-group">
            <label>Description of Incident</label>
            <textarea name="description" required rows="4" placeholder="Describe what happened in detail..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary btn-lg btn-full">Submit Claim</button>
        </form>
      <% } %>
    </div>
  </div>
</section>
<%- include('../partials/footer') %>